# Finnhub API key for live stock & crypto quotes.
# Get a free key at https://finnhub.io/dashboard and copy this file to `.env`.
VITE_FINNHUB_API_KEY=

# Google Maps Platform key for the dashboard Traffic module (live drive times
# with current traffic via the Routes API, plus an embedded route map via the
# Maps Embed API). Enable both "Routes API" and "Maps Embed API" for the key.
# Without it, the Traffic module shows demo estimates and hides the map.
VITE_GOOGLE_MAPS_API_KEY=

# Spotify app Client ID for full-track playback in the Spotify module (OAuth +
# Web Playback SDK; requires a Premium account to stream). Create an app at
# https://developer.spotify.com/dashboard and add your app URL(s) as Redirect
# URIs, e.g. http://127.0.0.1:5173/ and https://<user>.github.io/home-center/.
# Without it, the Spotify module shows the embed player (30-second previews).
VITE_SPOTIFY_CLIENT_ID=

# --- Future: Home Assistant integration (not used yet, mock state for now) ---
# VITE_HASS_BASE_URL=http://homeassistant.local:8123
# VITE_HASS_TOKEN=
