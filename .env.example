# Finnhub API key for live stock & crypto quotes.
# Get a free key at https://finnhub.io/dashboard and copy this file to `.env`.
VITE_FINNHUB_API_KEY=

# Google Maps Platform key for the dashboard Traffic module (live drive times
# with current traffic via the Routes API). Enable the "Routes API" for the key.
# Without it, the Traffic module shows demo estimates.
VITE_GOOGLE_MAPS_API_KEY=

# --- Future: Home Assistant integration (not used yet, mock state for now) ---
# VITE_HASS_BASE_URL=http://homeassistant.local:8123
# VITE_HASS_TOKEN=
